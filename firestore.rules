rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function validRole(role) {
      return role in ['user', 'broker', 'admin'];
    }

    function validSavedWrite(data) {
      return data.userId == request.auth.uid
        && data.propertyId is string
        && data.propertyId.size() > 0
        && data.isFavorite is bool
        && data.forComparison is bool;
    }


    function validPropertyCreate(data) {
      return data.title is string
        && data.title.size() >= 3
        && data.price is int
        && data.price > 0
        && data.city is string
        && data.city.size() >= 2
        && data.bhk is int
        && data.bhk > 0
        && data.imageUrls is list
        && data.imageUrls.size() > 0
        && data.status == 'pending'
        && data.verificationStatus == 'pending'
        && data.createdBy == request.auth.uid;
    }

    function ownerCanUpdateProperty() {
      return resource.data.uploadedBy == request.auth.uid
        && request.resource.data.verificationStatus == resource.data.verificationStatus
        && request.resource.data.status == resource.data.status
        && request.resource.data.rejectionReason == resource.data.rejectionReason
        && request.resource.data.moderatedBy == resource.data.moderatedBy
        && request.resource.data.moderatedAt == resource.data.moderatedAt;
    }

    function validAdminModerationUpdate() {
      return isAdmin()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'verificationStatus',
          'status',
          'rejectionReason',
          'moderatedBy',
          'moderatedAt'
        ])
        && request.resource.data.verificationStatus in ['approved', 'rejected']
        && request.resource.data.status == request.resource.data.verificationStatus
        && request.resource.data.moderatedBy == request.auth.uid
        && request.resource.data.moderatedAt is timestamp
        && (
          (request.resource.data.verificationStatus == 'approved'
            && !(request.resource.data.keys().hasAny(['rejectionReason'])) )
          ||
          (request.resource.data.verificationStatus == 'rejected'
            && request.resource.data.rejectionReason is string
            && request.resource.data.rejectionReason.size() > 0)
        );
    }

    match /properties/{propertyId} {
      allow read: if true;
      allow create: if signedIn() && validPropertyCreate(request.resource.data);
      allow update: if signedIn() && (ownerCanUpdateProperty() || validAdminModerationUpdate());
      allow delete: if signedIn() && resource.data.uploadedBy == request.auth.uid;
    }

    match /activities/{activityId} {
      allow create: if signedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /property_audit_logs/{auditId} {
      allow create: if isAdmin() && request.resource.data.performedBy == request.auth.uid;
      allow read: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow create: if isAdmin()
        || (signedIn()
          && request.resource.data.actorId == request.auth.uid
          && request.resource.data.userId is string
          && request.resource.data.type is string
          && request.resource.data.title is string
          && request.resource.data.message is string
          && request.resource.data.read is bool);
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['read', 'readAt'])
        && request.resource.data.read is bool;
    }

    match /visit_requests/{requestId} {
      allow create: if signedIn() && request.resource.data.buyerId == request.auth.uid;
      allow read: if signedIn() &&
        (resource.data.buyerId == request.auth.uid || resource.data.brokerId == request.auth.uid);
      allow update: if signedIn() && resource.data.brokerId == request.auth.uid;
    }



    match /offers/{offerId} {
      allow create: if signedIn()
        && request.resource.data.buyerId == request.auth.uid
        && request.resource.data.sellerId is string
        && request.resource.data.propertyId is string
        && request.resource.data.amount is int
        && request.resource.data.amount > 0
        && request.resource.data.status == 'pending'
        && request.resource.data.history is list;

      allow read: if signedIn()
        && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid);

      allow update: if signedIn()
        && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid)
        && request.resource.data.propertyId == resource.data.propertyId
        && request.resource.data.buyerId == resource.data.buyerId
        && request.resource.data.sellerId == resource.data.sellerId
        && request.resource.data.amount is int
        && request.resource.data.amount > 0
        && request.resource.data.history is list;
    }

    match /saved/{savedId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && validSavedWrite(request.resource.data);
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && validSavedWrite(request.resource.data)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.propertyId == resource.data.propertyId;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if signedIn()
        && request.auth.uid == userId
        && validRole(request.resource.data.role)
        && request.resource.data.phone is string;
      allow update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.role == resource.data.role
        && request.resource.data.createdAt == resource.data.createdAt;

      match /favorites/{propertyId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
