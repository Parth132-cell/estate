rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /properties/{propertyId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if signedIn() && resource.data.uploadedBy == request.auth.uid;
    }

    match /activities/{activityId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /visit_requests/{requestId} {
      allow create: if signedIn() && request.resource.data.buyerId == request.auth.uid;
      allow read: if signedIn() &&
        (resource.data.buyerId == request.auth.uid || resource.data.brokerId == request.auth.uid);
      allow update: if signedIn() && resource.data.brokerId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if signedIn() && request.auth.uid == userId;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
