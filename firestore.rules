rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function validRole(role) {
      return role in ['user', 'broker', 'admin'];
    }

    function validPropertyCreate(data) {
      return data.title is string
        && data.title.size() >= 3
        && data.price is int
        && data.price > 0
        && data.city is string
        && data.city.size() >= 2
        && data.bhk is int
        && data.bhk > 0
        && data.imageUrls is list
        && data.imageUrls.size() > 0
        && data.status == 'pending'
        && data.createdBy == request.auth.uid;
    }

    match /properties/{propertyId} {
      allow read: if true;
      allow create: if signedIn() && validPropertyCreate(request.resource.data);
      allow update, delete: if signedIn() && resource.data.uploadedBy == request.auth.uid;
    }

    match /activities/{activityId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /visit_requests/{requestId} {
      allow create: if signedIn() && request.resource.data.buyerId == request.auth.uid;
      allow read: if signedIn() &&
        (resource.data.buyerId == request.auth.uid || resource.data.brokerId == request.auth.uid);
      allow update: if signedIn() && resource.data.brokerId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if signedIn()
        && request.auth.uid == userId
        && validRole(request.resource.data.role)
        && request.resource.data.phone is string;
      allow update: if signedIn()
        && request.auth.uid == userId
        && validRole(request.resource.data.role)
        && request.resource.data.createdAt == resource.data.createdAt;

      match /favorites/{propertyId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
